# These environment variables configure the Vite frontend build.
# For local development, these are optional as the defaults point to localhost.
# For production deployment (e.g. Vercel), set these in your dashboard.

# The base URL for the FastAPI backend API
VITE_API_BASE_URL=https://your-backend-app.onrender.com

# The base URL for the FastAPI WebSocket connection
VITE_WS_BASE_URL=wss://your-backend-app.onrender.com/ws/market
